{
  "info": {
    "name": "HealthCareGov API",
    "description": "Complete Postman collection for HealthCareGov - Public Healthcare & Hospital Management System. Base URL: http://localhost:9090. Authenticate via POST /api/users/login and set the returned token as the {{token}} variable.",
